---
interface Props {
  ui?: {
    words?: string;
    wpm?: string;
    accuracy?: string;
    timeUp?: string;
    playAgain?: string;
    share?: string;
    copied?: string;
  };
  wordPool?: string[];
}

const { ui = {}, wordPool = [] } = Astro.props;

const labels = {
  words: ui.words ?? "Words",
  wpm: ui.wpm ?? "WPM",
  accuracy: ui.accuracy ?? "Accuracy",
  timeUp: ui.timeUp ?? "Time's Up!",
  playAgain: ui.playAgain ?? "Play Again",
  share: ui.share ?? "Share",
  copied: ui.copied ?? "Copied!",
};
---

<div class="typing">
  <div class="typing-timer">
    <div class="typing-timer__bar" id="timerBar"></div>
    <span class="typing-timer__text" id="timerText">60</span>
  </div>

  <div class="typing-stats-live">
    <div class="typing-stats-live__item">
      <span class="typing-stats-live__label">{labels.words}</span>
      <span class="typing-stats-live__value" id="wordCount">0</span>
    </div>
    <div class="typing-stats-live__item">
      <span class="typing-stats-live__label">{labels.wpm}</span>
      <span class="typing-stats-live__value" id="wpmLive">0</span>
    </div>
    <div class="typing-stats-live__item">
      <span class="typing-stats-live__label">{labels.accuracy}</span>
      <span class="typing-stats-live__value" id="accLive">100%</span>
    </div>
  </div>

  <div class="typing-arena">
    <div class="typing-arena__words">
      <div class="typing-arena__current" id="wordDisplay"></div>
      <div class="typing-arena__next" id="nextWordDisplay"></div>
    </div>
  </div>

  <div class="typing-results" id="resultsScreen">
    <div class="typing-results__overlay"></div>
    <div class="typing-results__podium">
      <h2 class="typing-results__title">{labels.timeUp}</h2>

      <div class="typing-results__stats-grid">
        <div class="typing-results__stat">
          <div class="typing-results__label">{labels.words}</div>
          <div class="typing-results__value" id="finalWords">0</div>
        </div>
        <div class="typing-results__stat typing-results__stat--highlight">
          <div class="typing-results__label">{labels.wpm}</div>
          <div class="typing-results__value" id="finalWPM">0</div>
        </div>
        <div class="typing-results__stat">
          <div class="typing-results__label">{labels.accuracy}</div>
          <div class="typing-results__value" id="finalAcc">100%</div>
        </div>
      </div>

      <div class="typing-results__grid" id="resultGrid"></div>

      <div class="typing-results__actions">
        <button
          class="typing-results__btn typing-results__btn--primary"
          id="restartBtn">{labels.playAgain}</button
        >
        <button
          class="typing-results__btn typing-results__btn--secondary"
          id="shareBtn">{labels.share}</button
        >
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ wordPool, labels }}>
  const WORDS =
    wordPool && wordPool.length > 0
      ? wordPool
      : [
          "word",
          "test",
          "typing",
          "speed",
          "accuracy",
          "practice",
          "game",
          "challenge",
          "keyboard",
          "skill",
        ];

  const GAME = {
    timeLeft: 60,
    running: false,
    started: false,
    words: [],
    errors: [],
    startTime: 0,
    timerInterval: null,
    currentWord: "",
    nextWord: "",
    typed: "",
    hasErrorInCurrentWord: false,
  };

  function getRandomWord() {
    return WORDS[Math.floor(Math.random() * WORDS.length)];
  }

  function startGame() {
    GAME.running = true;
    GAME.started = false;
    GAME.timeLeft = 60;
    GAME.words = [];
    GAME.errors = [];
    GAME.currentWord = getRandomWord();
    GAME.nextWord = getRandomWord();
    GAME.typed = "";
    GAME.hasErrorInCurrentWord = false;

    render();
  }

  function initializeTimer() {
    if (GAME.started) return;
    GAME.started = true;
    GAME.startTime = Date.now();
    startTimer();
  }

  function startTimer() {
    GAME.timerInterval = setInterval(() => {
      if (!GAME.running) {
        clearInterval(GAME.timerInterval);
        return;
      }

      GAME.timeLeft = Math.max(
        0,
        60 - Math.floor((Date.now() - GAME.startTime) / 1000),
      );

      const timerText = document.getElementById("timerText");
      const timerBar = document.getElementById("timerBar");

      if (timerText) timerText.textContent = GAME.timeLeft;
      if (timerBar) timerBar.style.width = (GAME.timeLeft / 60) * 100 + "%";

      if (GAME.timeLeft === 0) {
        clearInterval(GAME.timerInterval);
        endGame();
      }
    }, 100);
  }

  function calculateStats() {
    const elapsed = (Date.now() - GAME.startTime) / 1000;
    const wpm =
      GAME.words.length > 0
        ? Math.round((GAME.words.length * 5) / (elapsed / 60))
        : 0;
    const acc =
      GAME.words.length > 0
        ? Math.round(
            (GAME.words.length / (GAME.words.length + GAME.errors.length)) *
              100,
          )
        : 100;
    return { wpm, acc };
  }

  function updateStats() {
    const { wpm, acc } = calculateStats();
    const wordCountEl = document.getElementById("wordCount");
    const wpmLiveEl = document.getElementById("wpmLive");
    const accLiveEl = document.getElementById("accLive");
    if (wordCountEl) wordCountEl.textContent = GAME.words.length;
    if (wpmLiveEl) wpmLiveEl.textContent = wpm;
    if (accLiveEl) accLiveEl.textContent = acc + "%";
  }

  function render() {
    const display = document.getElementById("wordDisplay");
    const nextDisplay = document.getElementById("nextWordDisplay");

    if (!display) return;

    const typed = GAME.typed;
    const target = GAME.currentWord;

    let html = "";
    for (let i = 0; i < target.length; i++) {
      const char = target[i];
      let cls = "typing-char";
      if (i < typed.length) {
        cls += typed[i] === char ? " typing-char--ok" : " typing-char--bad";
      } else if (i === typed.length) {
        cls += " typing-char--cur";
      }
      html += `<span class="${cls}">${char}</span>`;
    }
    display.innerHTML = html;

    if (nextDisplay) {
      const progress = typed.length / target.length;
      nextDisplay.textContent = GAME.nextWord;
      nextDisplay.style.opacity = Math.max(0, progress - 0.4) * 1.67;
      nextDisplay.style.transform = `translateX(-50%) scale(0.6) translateY(${Math.max(0, progress - 0.4) * 20}px)`;
    }

    updateStats();
  }

  function completeWord() {
    const display = document.getElementById("wordDisplay");

    if (display) {
      display.classList.add("typing-complete");
      setTimeout(() => {
        display.classList.remove("typing-complete");
      }, 400);
    }

    document.body.style.animation = "none";
    GAME.words.push(GAME.currentWord);
    GAME.currentWord = GAME.nextWord;
    GAME.nextWord = getRandomWord();
    GAME.typed = "";
    GAME.hasErrorInCurrentWord = false;

    render();
  }

  function showError() {
    document.body.style.animation = "none";
    setTimeout(() => {
      document.body.style.animation = "typing-pulse-error 0.2s";
    }, 10);

    GAME.errors.push(true);
    GAME.timeLeft = Math.max(0, GAME.timeLeft - 3);
  }

  function generateGridHTML() {
    const ok = Array(GAME.words.length)
      .fill('<div class="typing-grid-item typing-grid-item--ok">G</div>')
      .join("");
    const err = Array(GAME.errors.length)
      .fill('<div class="typing-grid-item typing-grid-item--error">W</div>')
      .join("");
    return ok + err;
  }

  function generateGridText() {
    const items = [
      ...Array(GAME.words.length).fill("[G]"),
      ...Array(GAME.errors.length).fill("[W]"),
    ];
    let result = "";
    for (let i = 0; i < items.length; i++) {
      result += items[i];
      if ((i + 1) % 5 === 0) result += "\n";
    }
    return result.trim();
  }

  function endGame() {
    GAME.running = false;
    const { wpm, acc } = calculateStats();
    const finalWordsEl = document.getElementById("finalWords");
    const finalWPMEl = document.getElementById("finalWPM");
    const finalAccEl = document.getElementById("finalAcc");
    if (finalWordsEl) finalWordsEl.textContent = GAME.words.length;
    if (finalWPMEl) finalWPMEl.textContent = wpm;
    if (finalAccEl) finalAccEl.textContent = acc + "%";
    const grid = document.getElementById("resultGrid");
    if (grid) grid.innerHTML = generateGridHTML();
    const resultsScreen = document.getElementById("resultsScreen");
    if (resultsScreen) resultsScreen.style.display = "flex";
  }

  function checkWordMatch(typed, target) {
    for (let i = 0; i < typed.length; i++)
      if (typed[i] !== target[i]) return false;
    return true;
  }

  function handleCharInput(char) {
    if (!GAME.started) initializeTimer();
    const target = GAME.currentWord;
    if (GAME.typed.length >= target.length) return;
    GAME.typed += char;
    if (GAME.typed === target) {
      completeWord();
    } else {
      const hasError = !checkWordMatch(GAME.typed, target);
      if (hasError && !GAME.hasErrorInCurrentWord) {
        GAME.hasErrorInCurrentWord = true;
        showError();
      } else if (!hasError) {
        document.body.style.animation = "none";
      }
      render();
    }
  }

  function setupButtons() {
    const restartBtn = document.getElementById("restartBtn");
    const shareBtn = document.getElementById("shareBtn");
    const resultsScreen = document.getElementById("resultsScreen");
    if (restartBtn) {
      restartBtn.addEventListener("click", () => {
        if (resultsScreen) resultsScreen.style.display = "none";
        startGame();
      });
    }
    if (shareBtn) {
      shareBtn.addEventListener("click", () => {
        const gridText = generateGridText();
        const finalWPMEl = document.getElementById("finalWPM");
        const finalAccEl = document.getElementById("finalAcc");
        const wpm = finalWPMEl ? finalWPMEl.textContent : "0";
        const acc = finalAccEl ? finalAccEl.textContent : "100%";
        const text = `Typing Sprint\n\n${gridText}\n${GAME.words.length} words • ${wpm} WPM • ${acc}\n\nTry to beat me: jjlmoya.es`;
        navigator.clipboard.writeText(text).then(() => {
          if (shareBtn) {
            shareBtn.textContent = labels.copied;
            setTimeout(() => {
              shareBtn.textContent = labels.share;
            }, 2000);
          }
        });
      });
    }
  }

  function init() {
    setupButtons();
    document.addEventListener("keydown", (e) => {
      if (!GAME.running) return;
      const char = e.key.toLowerCase();
      if (!/^[a-zàâäèéêëìíîïòóôöùúûüñçáéíóú]$/.test(char)) {
        if (char === "backspace") {
          GAME.typed = GAME.typed.slice(0, -1);
          render();
        }
        return;
      }
      handleCharInput(char);
    });
    startGame();
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>

<style>
  /* stylelint-disable */
  /* eslint-disable */
  .typing {
    --typing-primary: #f43f5e;
    --typing-secondary: #fb7185;
    --typing-accent: #06b6d4;
    --typing-bg: #fff;
    --typing-text: #1e293b;
    --typing-text-light: #64748b;
    --typing-border: #e2e8f0;
    --typing-error: #ef4444;
    --typing-white: #fff;
  }

  :global(.theme-dark) .typing {
    --typing-bg: #0f172a;
    --typing-text: #f1f5f9;
    --typing-text-light: #cbd5e1;
    --typing-border: #334155;
  }

  .typing {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    background: var(--typing-bg);
    color: var(--typing-text);
  }

  .typing-timer {
    position: relative;
    margin-bottom: 2rem;
    text-align: center;
  }

  .typing-timer__bar {
    position: absolute;
    top: 0;
    left: 0;
    height: 4px;
    background: linear-gradient(
      90deg,
      var(--typing-primary),
      var(--typing-secondary)
    );
    border-radius: 2px;
    transition: width 0.1s linear;
    width: 100%;
  }

  .typing-timer__text {
    display: inline-block;
    font-size: 3rem;
    font-weight: 900;
    color: var(--typing-primary);
    margin-top: 1rem;
  }

  .typing-stats-live {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .typing-stats-live__item {
    padding: 1rem;
    border: 1px solid var(--typing-border);
    border-radius: 0.5rem;
    transition: all 0.2s ease;
  }

  .typing-stats-live__item:hover {
    border-color: var(--typing-primary);
    box-shadow: 0 0 10px rgba(244, 63, 94, 0.1);
  }

  .typing-stats-live__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--typing-text-light);
    margin-bottom: 0.5rem;
  }

  .typing-stats-live__value {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--typing-primary);
  }

  .typing-arena {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
    text-align: center;
    margin-top: 2rem;
  }

  .typing-arena__words {
    position: relative;
    min-height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .typing-arena__current {
    font-size: 4rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    line-height: 1.2;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.2rem;
    word-break: break-word;
    min-height: 120px;
  }

  .typing-arena__next {
    position: absolute;
    bottom: -60px;
    left: 50%;
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--typing-text-light);
    opacity: 0;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .typing-arena__display {
    font-size: 3.5rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    line-height: 1.2;
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.2rem;
    word-break: break-word;
  }

  .typing-char {
    transition: all 0.05s ease;
    color: var(--typing-text-light);
  }

  .typing-char--ok {
    color: var(--typing-accent);
    font-weight: 900;
    background: rgba(6, 182, 212, 0.15);
    border-radius: 0.25rem;
    padding: 0.15rem 0.1rem;
  }

  .typing-char--bad {
    color: var(--typing-error);
    background: rgba(239, 68, 68, 0.2);
    border-radius: 0.25rem;
    animation: typing-shake 0.15s ease;
  }

  @keyframes typing-shake {
    0%,
    100% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-2px);
    }
    75% {
      transform: translateX(2px);
    }
  }

  .typing-char--cur {
    color: white;
    background: var(--typing-primary);
    font-weight: 900;
    border-radius: 0.25rem;
    padding: 0.15rem 0.1rem;
    animation: typing-blink 0.6s infinite;
    box-shadow: 0 0 8px rgba(244, 63, 94, 0.6);
  }

  @keyframes typing-blink {
    0%,
    40% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0.4;
    }
  }

  .typing-complete {
    animation: typing-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
  }

  @keyframes typing-pop {
    0% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.1);
    }
    100% {
      transform: scale(0.9);
      opacity: 0.5;
    }
  }

  @keyframes typing-error-shake {
    0%,
    100% {
      transform: translateX(0);
    }
    10% {
      transform: translateX(-5px);
    }
    20% {
      transform: translateX(5px);
    }
    30% {
      transform: translateX(-5px);
    }
    40% {
      transform: translateX(5px);
    }
  }

  @keyframes typing-pulse-error {
    0% {
      background-color: transparent;
    }
    50% {
      background-color: rgba(239, 68, 68, 0.1);
    }
    100% {
      background-color: transparent;
    }
  }

  .typing-results {
    display: none;
    position: fixed;
    inset: 0;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    animation: typing-fadeIn 0.3s ease;
  }

  .typing-results__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .typing-results__podium {
    position: relative;
    background: var(--typing-bg);
    border-radius: 1.5rem;
    padding: 3rem 2.5rem;
    max-width: 500px;
    width: 90%;
    text-align: center;
    animation: typing-popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }

  .typing-results__title {
    font-size: 3rem;
    font-weight: 900;
    color: var(--typing-primary);
    margin-bottom: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .typing-results__stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .typing-results__stat {
    padding: 1.5rem 1rem;
    border: 2px solid var(--typing-border);
    border-radius: 0.75rem;
    transition: all 0.2s ease;
  }

  .typing-results__stat--highlight {
    border-color: var(--typing-primary);
    background: rgba(244, 63, 94, 0.1);
    transform: scale(1.05);
  }

  .typing-results__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--typing-text-light);
    margin-bottom: 0.5rem;
  }

  .typing-results__value {
    font-size: 2rem;
    font-weight: 900;
    color: var(--typing-primary);
  }

  .typing-results__grid {
    margin: 2rem 0;
    padding: 1.5rem;
    background: rgba(244, 63, 94, 0.05);
    border-radius: 0.75rem;
    font-family: "Outfit", sans-serif;
    font-size: 1rem;
    line-height: normal;
    white-space: pre-wrap;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    align-items: center;
    color: var(--typing-text-light);
    min-height: 60px;
  }

  .typing-grid-item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 0.5rem;
    font-weight: 900;
    font-size: 0.8rem;
    color: white;
    transition: transform 0.2s ease;
  }

  .typing-grid-item:hover {
    transform: scale(1.1);
  }

  .typing-grid-item--ok {
    background: var(--typing-accent);
    box-shadow: 0 4px 12px rgba(6, 182, 212, 0.3);
  }

  .typing-grid-item--error {
    background: var(--typing-error);
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
  }

  .typing-results__actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  .typing-results__btn {
    flex: 1;
    padding: 1rem;
    border: none;
    border-radius: 0.5rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 0.9rem;
  }

  .typing-results__btn--primary {
    background: var(--typing-primary);
    color: white;
  }

  .typing-results__btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(244, 63, 94, 0.3);
  }

  .typing-results__btn--secondary {
    background: var(--typing-border);
    color: var(--typing-text);
  }

  .typing-results__btn--secondary:hover {
    background: var(--typing-text-light);
  }

  .typing-modal {
    display: none !important;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    align-items: center;
    justify-content: center;
    z-index: 1000;
    animation: typing-fadeIn 0.2s ease;
    pointer-events: none;
  }

  @keyframes typing-fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .typing-modal__content {
    background: var(--typing-bg);
    border: 2px solid var(--typing-primary);
    border-radius: 1.5rem;
    padding: 3rem 2rem;
    max-width: 400px;
    width: 100%;
    text-align: center;
    animation: typing-popIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes typing-popIn {
    from {
      opacity: 0;
      transform: scale(0.8);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .typing-modal__title {
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 1.5rem;
    color: var(--typing-primary);
  }

  .typing-modal__score,
  .typing-modal__stats {
    font-size: 1rem;
    font-weight: 700;
    color: var(--typing-text-light);
    margin: 0.75rem 0;
  }

  .typing-modal__btn {
    margin-top: 2rem;
    padding: 1rem 2rem;
    background: var(--typing-primary);
    border: none;
    border-radius: 0.5rem;
    color: white;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .typing-modal__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(244, 63, 94, 0.2);
  }

  .typing-modal__btn:active {
    transform: translateY(0);
