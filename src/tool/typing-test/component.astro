---
import './TypingTest.css';

interface Props {
  ui?: {
    words?: string;
    wpm?: string;
    accuracy?: string;
    timeUp?: string;
    playAgain?: string;
    share?: string;
    copied?: string;
  };
  wordPool?: string[];
}

const { ui = {}, wordPool = [] } = Astro.props;

const labels = {
  words: ui.words ?? 'Words',
  wpm: ui.wpm ?? 'WPM',
  accuracy: ui.accuracy ?? 'Accuracy',
  timeUp: ui.timeUp ?? 'Time\'s Up!',
  playAgain: ui.playAgain ?? 'Play Again',
  share: ui.share ?? 'Share',
  copied: ui.copied ?? 'Copied!',
};
---

<div class="typing">
  <div class="typing-timer">
    <div class="typing-timer__bar" id="timerBar"></div>
    <span class="typing-timer__text" id="timerText">60</span>
  </div>

  <div class="typing-stats-live">
    <div class="typing-stats-live__item">
      <span class="typing-stats-live__label">{labels.words}</span>
      <span class="typing-stats-live__value" id="wordCount">0</span>
    </div>
    <div class="typing-stats-live__item">
      <span class="typing-stats-live__label">{labels.wpm}</span>
      <span class="typing-stats-live__value" id="wpmLive">0</span>
    </div>
    <div class="typing-stats-live__item">
      <span class="typing-stats-live__label">{labels.accuracy}</span>
      <span class="typing-stats-live__value" id="accLive">100%</span>
    </div>
  </div>

  <div class="typing-arena">
    <div class="typing-arena__words">
      <div class="typing-arena__current" id="wordDisplay"></div>
      <div class="typing-arena__next" id="nextWordDisplay"></div>
    </div>
  </div>

  <div class="typing-results" id="resultsScreen">
    <div class="typing-results__overlay"></div>
    <div class="typing-results__podium">
      <h2 class="typing-results__title">{labels.timeUp}</h2>

      <div class="typing-results__stats-grid">
        <div class="typing-results__stat">
          <div class="typing-results__label">{labels.words}</div>
          <div class="typing-results__value" id="finalWords">0</div>
        </div>
        <div class="typing-results__stat typing-results__stat--highlight">
          <div class="typing-results__label">{labels.wpm}</div>
          <div class="typing-results__value" id="finalWPM">0</div>
        </div>
        <div class="typing-results__stat">
          <div class="typing-results__label">{labels.accuracy}</div>
          <div class="typing-results__value" id="finalAcc">100%</div>
        </div>
      </div>

      <div class="typing-results__grid" id="resultGrid"></div>

      <div class="typing-results__actions">
        <button class="typing-results__btn typing-results__btn--primary" id="restartBtn">{labels.playAgain}</button>
        <button class="typing-results__btn typing-results__btn--secondary" id="shareBtn">{labels.share}</button>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ wordPool, labels }}>
  const WORDS = wordPool && wordPool.length > 0 ? wordPool : [
    "word", "test", "typing", "speed", "accuracy", "practice", "game", "challenge", "keyboard", "skill"
  ];

  const GAME = {
    timeLeft: 60, running: false, started: false, words: [], errors: [],
    startTime: 0, timerInterval: null, currentWord: "", nextWord: "",
    typed: "", hasErrorInCurrentWord: false
  };

  function getRandomWord() {
    return WORDS[Math.floor(Math.random() * WORDS.length)];
  }

  function startGame() {
    GAME.running = true;
    GAME.started = false;
    GAME.timeLeft = 60;
    GAME.words = [];
    GAME.errors = [];
    GAME.currentWord = getRandomWord();
    GAME.nextWord = getRandomWord();
    GAME.typed = "";
    GAME.hasErrorInCurrentWord = false;

    render();
  }

  function initializeTimer() {
    if (GAME.started) return;
    GAME.started = true;
    GAME.startTime = Date.now();
    startTimer();
  }

  function startTimer() {
    GAME.timerInterval = setInterval(() => {
      if (!GAME.running) {
        clearInterval(GAME.timerInterval);
        return;
      }

      GAME.timeLeft = Math.max(0, 60 - Math.floor((Date.now() - GAME.startTime) / 1000));

      const timerText = document.getElementById("timerText");
      const timerBar = document.getElementById("timerBar");

      if (timerText) timerText.textContent = GAME.timeLeft;
      if (timerBar) timerBar.style.width = (GAME.timeLeft / 60 * 100) + "%";

      if (GAME.timeLeft === 0) {
        clearInterval(GAME.timerInterval);
        endGame();
      }
    }, 100);
  }

  function calculateStats() {
    const elapsed = (Date.now() - GAME.startTime) / 1000;
    const wpm = GAME.words.length > 0 ? Math.round((GAME.words.length * 5) / (elapsed / 60)) : 0;
    const acc = GAME.words.length > 0 ? Math.round(((GAME.words.length / (GAME.words.length + GAME.errors.length)) * 100)) : 100;
    return { wpm, acc };
  }

  function updateStats() {
    const { wpm, acc } = calculateStats();
    const wordCountEl = document.getElementById("wordCount");
    const wpmLiveEl = document.getElementById("wpmLive");
    const accLiveEl = document.getElementById("accLive");
    if (wordCountEl) wordCountEl.textContent = GAME.words.length;
    if (wpmLiveEl) wpmLiveEl.textContent = wpm;
    if (accLiveEl) accLiveEl.textContent = acc + "%";
  }

  function render() {
    const display = document.getElementById("wordDisplay");
    const nextDisplay = document.getElementById("nextWordDisplay");

    if (!display) return;

    const typed = GAME.typed;
    const target = GAME.currentWord;

    let html = "";
    for (let i = 0; i < target.length; i++) {
      const char = target[i];
      let cls = "typing-char";
      if (i < typed.length) {
        cls += typed[i] === char ? " typing-char--ok" : " typing-char--bad";
      } else if (i === typed.length) {
        cls += " typing-char--cur";
      }
      html += `<span class="${cls}">${char}</span>`;
    }
    display.innerHTML = html;

    if (nextDisplay) {
      const progress = typed.length / target.length;
      nextDisplay.textContent = GAME.nextWord;
      nextDisplay.style.opacity = Math.max(0, progress - 0.4) * 1.67;
      nextDisplay.style.transform = `translateX(-50%) scale(0.6) translateY(${Math.max(0, progress - 0.4) * 20}px)`;
    }

    updateStats();
  }

  function completeWord() {
    const display = document.getElementById("wordDisplay");

    if (display) {
      display.classList.add("typing-complete");
      setTimeout(() => {
        display.classList.remove("typing-complete");
      }, 400);
    }

    document.body.style.animation = "none";
    GAME.words.push(GAME.currentWord);
    GAME.currentWord = GAME.nextWord;
    GAME.nextWord = getRandomWord();
    GAME.typed = "";
    GAME.hasErrorInCurrentWord = false;

    render();
  }

  function showError() {
    document.body.style.animation = "none";
    setTimeout(() => {
      document.body.style.animation = "typing-pulse-error 0.2s";
    }, 10);

    GAME.errors.push(true);
    GAME.timeLeft = Math.max(0, GAME.timeLeft - 3);
  }

  function generateGridHTML() {
    const ok = Array(GAME.words.length).fill('<div class="typing-grid-item typing-grid-item--ok">G</div>').join("");
    const err = Array(GAME.errors.length).fill('<div class="typing-grid-item typing-grid-item--error">W</div>').join("");
    return ok + err;
  }

  function generateGridText() {
    const items = [
      ...Array(GAME.words.length).fill("[G]"),
      ...Array(GAME.errors.length).fill("[W]")
    ];
    let result = "";
    for (let i = 0; i < items.length; i++) {
      result += items[i];
      if ((i + 1) % 5 === 0) result += "\n";
    }
    return result.trim();
  }

  function endGame() {
    GAME.running = false;
    const { wpm, acc } = calculateStats();
    const finalWordsEl = document.getElementById("finalWords");
    const finalWPMEl = document.getElementById("finalWPM");
    const finalAccEl = document.getElementById("finalAcc");
    if (finalWordsEl) finalWordsEl.textContent = GAME.words.length;
    if (finalWPMEl) finalWPMEl.textContent = wpm;
    if (finalAccEl) finalAccEl.textContent = acc + "%";
    const grid = document.getElementById("resultGrid");
    if (grid) grid.innerHTML = generateGridHTML();
    const resultsScreen = document.getElementById("resultsScreen");
    if (resultsScreen) resultsScreen.style.display = "flex";
  }

  function checkWordMatch(typed, target) {
    for (let i = 0; i < typed.length; i++)
      if (typed[i] !== target[i]) return false;
    return true;
  }

  function handleCharInput(char) {
    if (!GAME.started) initializeTimer();
    const target = GAME.currentWord;
    if (GAME.typed.length >= target.length) return;
    GAME.typed += char;
    if (GAME.typed === target) {
      completeWord();
    } else {
      const hasError = !checkWordMatch(GAME.typed, target);
      if (hasError && !GAME.hasErrorInCurrentWord) {
        GAME.hasErrorInCurrentWord = true;
        showError();
      } else if (!hasError) {
        document.body.style.animation = "none";
      }
      render();
    }
  }

  function setupButtons() {
    const restartBtn = document.getElementById("restartBtn");
    const shareBtn = document.getElementById("shareBtn");
    const resultsScreen = document.getElementById("resultsScreen");
    if (restartBtn) {
      restartBtn.addEventListener("click", () => {
        if (resultsScreen) resultsScreen.style.display = "none";
        startGame();
      });
    }
    if (shareBtn) {
      shareBtn.addEventListener("click", () => {
        const gridText = generateGridText();
        const finalWPMEl = document.getElementById("finalWPM");
        const finalAccEl = document.getElementById("finalAcc");
        const wpm = finalWPMEl ? finalWPMEl.textContent : "0";
        const acc = finalAccEl ? finalAccEl.textContent : "100%";
        const text = `Typing Sprint\n\n${gridText}\n${GAME.words.length} words • ${wpm} WPM • ${acc}\n\nTry to beat me: jjlmoya.es`;
        navigator.clipboard.writeText(text).then(() => {
          if (shareBtn) {
            shareBtn.textContent = labels.copied;
            setTimeout(() => {
              shareBtn.textContent = labels.share;
            }, 2000);
          }
        });
      });
    }
  }

  function init() {
    setupButtons();
    document.addEventListener("keydown", (e) => {
      if (!GAME.running) return;
      const char = e.key.toLowerCase();
      if (!/^[a-zàâäèéêëìíîïòóôöùúûüñçáéíóú]$/.test(char)) {
        if (char === "backspace") {
          GAME.typed = GAME.typed.slice(0, -1);
          render();
        }
        return;
      }
      handleCharInput(char);
    });
    startGame();
  }
if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>